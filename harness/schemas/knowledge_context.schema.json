{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "knowledge_context",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_version",
    "task_id",
    "agent_name",
    "source_mode",
    "query",
    "refs",
    "artifact_ref",
    "excerpt_meta"
  ],
  "properties": {
    "schema_version": {"type": "string", "minLength": 1},
    "artifact_version": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "agent_name": {"type": "string", "minLength": 1},
    "source_mode": {"type": "string", "minLength": 1},
    "query": {"type": "string", "minLength": 0},
    "refs": {"type": "array", "items": {"type": "string"}},
    "artifact_ref": {"type": "string", "minLength": 1},
    "excerpt_meta": {"type": "array", "items": {"type": "string"}},
    "note_path": {"type": "string", "minLength": 0}
  },
  "additionalProperties": true
}
