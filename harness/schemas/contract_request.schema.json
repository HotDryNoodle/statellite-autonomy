{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "contract_request",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_version",
    "task_id",
    "expert",
    "affected_specs",
    "clause_refs"
  ],
  "properties": {
    "schema_version": {"type": "string", "minLength": 1},
    "artifact_version": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "expert": {"type": "string", "minLength": 1},
    "affected_specs": {"type": "array", "items": {"type": "string"}},
    "clause_refs": {"type": "array", "items": {"type": "string"}},
    "summary": {"type": "string"},
    "proposal": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
